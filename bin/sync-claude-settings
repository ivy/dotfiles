            "Bash(bundle:*)",
            "Bash(cargo:*)",
            "Bash(cat:*)",
            "Bash(chezmoi diff:*)",
            "Bash(clear:*)",
            "Bash(column:*)",
            "Bash(comm:*)",
            "Bash(cut:*)",
            "Bash(date:*)",
            "Bash(defaults read:*)",
            "Bash(diff:*)",
            "Bash(dig:*)",
            "Bash(dirname:*)",
            "Bash(docker compose:*)",
            "Bash(docker-compose:*)",
