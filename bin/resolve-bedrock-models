#!/usr/bin/env bash
#
# resolve-bedrock-models -- Resolve latest AWS Bedrock Claude model per tier
#
# Queries AWS Bedrock for active Anthropic Claude foundation models and
# outputs the latest cross-region inference profile ID for each tier
# (opus, sonnet, haiku) as JSON.
#
# Results are cached in $XDG_DATA_HOME/dotfiles/ and refreshed every 24 hours.
# A stale cache is preferred over returning nothing on refresh failure.
#
# Usage:
#   bin/resolve-bedrock-models
#
# Requires: aws CLI (with valid credentials), jq
#
# Output (stdout):
#   {"haiku":"us.anthropic.claude-...","opus":"us.anthropic.claude-...","sonnet":"us.anthropic.claude-..."}
#

[[ -n "${DEBUG:-}" ]] && set -o xtrace
set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

export AWS_PROFILE=default

CACHE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/dotfiles"
CACHE_FILE="${CACHE_DIR}/bedrock-models.json"
CACHE_MAX_AGE=86400 # 24 hours

require_command() {
  local cmd="$1"
  local hint="${2:-}"

  if ! command -v "${cmd}" >/dev/null 2>&1; then
    printf 'warning: required command "%s" not found in PATH\n' "${cmd}" >&2
    [[ -n "${hint}" ]] && printf '  hint: %s\n' "${hint}" >&2
    echo '{}'
    exit 0
  fi
}

cache_mtime() {
  local mtime
  mtime=$(stat -c %Y "$1" 2>/dev/null) ||
    mtime=$(stat -f %m "$1" 2>/dev/null) ||
    mtime=0
  printf '%s\n' "${mtime}"
}

cache_is_fresh() {
  [[ -f "${CACHE_FILE}" ]] || return 1
  local now mtime age
  now=$(date +%s)
  mtime=$(cache_mtime "${CACHE_FILE}")
  age=$(( now - mtime ))
  (( age < CACHE_MAX_AGE ))
}

fetch_foundation_models() {
  aws bedrock list-foundation-models \
    --output json \
    --by-provider anthropic
}

resolve_latest_per_tier() {
  jq '
    .modelSummaries
    | map(select(
        .modelLifecycle.status == "ACTIVE"
        and (.modelId | startswith("anthropic.claude-"))
        and (.modelId | test(":\\d+k$") | not)
    ))
    | map(.modelId)
    | {
        opus:   map(select(contains("opus")))   | sort | last,
        sonnet: map(select(contains("sonnet"))) | sort | last,
        haiku:  map(select(contains("haiku")))  | sort | last
      }
    | with_entries(select(.value != null))
    | with_entries(.value = "us." + .value)
  '
}

main() {
  require_command aws "install the AWS CLI: https://aws.amazon.com/cli/"
  require_command jq "install jq: https://jqlang.github.io/jq/"

  if cache_is_fresh; then
    cat "${CACHE_FILE}"
    return
  fi

  mkdir -p "${CACHE_DIR}"

  local result
  result=$(fetch_foundation_models | resolve_latest_per_tier) || true

  if [[ -n "${result}" && "${result}" != "{}" ]]; then
    printf '%s\n' "${result}" > "${CACHE_FILE}"
    printf '%s\n' "${result}"
  elif [[ -f "${CACHE_FILE}" ]]; then
    cat "${CACHE_FILE}"
  else
    echo '{}'
  fi
}

main "$@"
