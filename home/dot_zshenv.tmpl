# XDG Base Directory specification
# https://specifications.freedesktop.org/basedir-spec/latest/
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# XDG system directories
export XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
export XDG_CONFIG_DIRS="${XDG_CONFIG_DIRS:-/etc/xdg}"

# Keep PATH entries unique — collapse duplicates created by macOS path_helper
# and the shim re-prepends in .zprofile/.zshenv (first occurrence wins, so a
# re-prepended dir is promoted to the front and its stale copy dropped).
typeset -U path PATH

# Add ~/.local/bin to front of PATH if not already present
if [[ -d "$HOME/.local/bin" && ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

# Mise activation (SHIM MODE) for NON-LOGIN shells: prepend the shims dir so
# `which <tool>` resolves to ~/.local/share/mise/shims/<tool>. Deliberately NOT
# `mise activate zsh` (hook-env) — that strips this dir and points tools at the
# install path, so `which <tool>` no longer reports the shim. LOGIN shells get
# the same via .zprofile, which re-asserts it AFTER macOS path_helper reorders PATH.
if [[ -d "$HOME/.local/share/mise/shims" && ":$PATH:" != *":$HOME/.local/share/mise/shims:"* ]]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

# Editor configuration
export EDITOR="nvim"

# Pager configuration
export PAGER="less"
export LESS="-FRX"

# NPM security hardening - disable postinstall scripts for global CLI tools
export NPM_CONFIG_IGNORE_SCRIPTS=1
export NPM_CONFIG_AUDIT=false
export NPM_CONFIG_FUND=false

{{- if and (eq .chezmoi.os "darwin") (glob (joinPath .chezmoi.homeDir "Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock")) }}
# 1Password SSH agent
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}

# Source system-specific overrides and additions *last*
if [[ -r "$HOME/.zshenv.local" ]]; then
  source "$HOME/.zshenv.local"
fi
