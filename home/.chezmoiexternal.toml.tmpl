# Chezmoi External Dependencies
# All dependencies are pinned to specific commit SHAs for security and reproducibility.
# Automated updates are managed by custom Renovate managers in renovate.json5 using
# the git-refs datasource to track upstream master branches and propose SHA updates.

# =============================================================================
# Zsh (only installed if zsh is available)
# =============================================================================
{{ if lookPath "zsh" }}
# Oh-My-Zsh framework
[".oh-my-zsh"]
    type = "archive"
    url = "https://github.com/ohmyzsh/ohmyzsh/archive/2525dae6613652ec9cb572bdc2fdf80ef837a967.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "24h"

# Zsh Autosuggestions plugin
[".config/zsh/plugins/zsh-autosuggestions"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-autosuggestions/archive/85919cd1ffa7d2d5412f6d3fe437ebdbeeec4fc5.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"

# Zsh Syntax Highlighting plugin
[".config/zsh/plugins/zsh-syntax-highlighting"]
    type = "archive"
    url = "https://github.com/zsh-users/zsh-syntax-highlighting/archive/5eb677bb0fa9a3e60f0eff031dc13926e093df92.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "168h"
{{ end }}

# =============================================================================
# Terminal themes
# =============================================================================

# Catppuccin Ghostty themes
[".config/ghostty/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/ghostty/archive/5a58926563ddacbde4a12b4a347464c2c6945393.tar.gz"
    stripComponents = 2
    include = ["*/themes/**"]
    refreshPeriod = "168h"

# =============================================================================
# CLI tools (source installs for cross-platform support)
# =============================================================================

# hk (git hooks manager) — fork with global config support
# Temporary: building from fork branch until fix is merged upstream
{{ if lookPath "cargo" }}
[".local/src/hk"]
    type = "git-repo"
    url = "https://github.com/ivy/hk.git"
    refreshPeriod = "24h"
    [".local/src/hk".clone]
        args = ["--recurse-submodules", "--branch", "fix/hkrc-config-format"]
    [".local/src/hk".pull]
        args = ["--recurse-submodules"]
{{ end }}

# =============================================================================
# Tmux plugins (managed via .chezmoidata/tmux-plugins.yaml, updated by Renovate)
# =============================================================================
{{ range .tmuxPlugins }}
[".config/tmux/plugins/{{ .name }}"]
    type = "archive"
    url = "https://github.com/{{ .repo }}/archive/{{ .commit }}.tar.gz"
    exact = true
    stripComponents = 1
    refreshPeriod = "8760h"
{{ end }}
