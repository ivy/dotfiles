{
  "display": {
    "autoWrap": true,
    "budget": {
      "today": {
        "amount": 0
      }
    },
    "charset": "unicode",
    "colorCompatibility": "auto",
    "lines": [
      {
        "segments": {
          "context": {
            "displayStyle": "text",
            "enabled": true,
            "showPercentageOnly": true
          },
          "directory": {
            "enabled": true,
            "style": "basename"
          },
          "git": {
            "enabled": true
          },
          "model": {
            "enabled": true
          },
          "today": {
            "enabled": true,
            "type": "cost"
          }
        }
      }
    ],
    "padding": 1,
    "style": "capsule"
  },
  "modelContextLimits": {
    "sonnet": 200000
  },
  "theme": "custom"
}
