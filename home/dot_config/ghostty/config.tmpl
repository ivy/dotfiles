# Ghostty configuration
# Font Configuration
font-family = FiraCode Nerd Font Mono
font-size = 14
font-feature = +calt,+liga,+dlig

# Shell Integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

{{ if eq .chezmoi.os "darwin" -}}
# Hide the titlebar but KEEP the native window frame — rounded corners and the
# window shadow survive. `window-decoration = none` would square the corners.
# We live in tmux + splits and never open native tabs, so no tab bar appears.
macos-titlebar-style = hidden

# Keybindings (macOS)
keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_tab
{{ else -}}
# Disable the tab bar entirely (GTK/Linux dedicated toggle)
window-show-tab-bar = never

# Keybindings (Linux)
keybind = ctrl+shift+d=new_split:right
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+w=close_tab
{{ end -}}

# Theme
theme = light:catppuccin-latte.conf,dark:catppuccin-mocha.conf
