amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"

hooks {
  ["pre-commit"] {
    steps {
      ["gitleaks"] {
        check = "gitleaks protect --staged"
      }
    }
  }
  ["pre-push"] {
    steps {
      ["gitleaks"] {
        check = "gitleaks protect --staged"
      }
    }
  }
  ["check"] {
    steps {
      ["gitleaks"] {
        check = "gitleaks git --no-banner --verbose"
      }
    }
  }
}
